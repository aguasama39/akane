{
  "name": "akane",
  "version": "1.0.7",
  "description": "Sleek manga reader desktop app",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite build --watch\" \"wait-on dist-react/index.html && electron .\"",
    "build": "vite build",
    "start": "vite build && electron .",
    "dist": "vite build && electron-builder --win --x64",
    "dist:linux": "vite build && electron-builder --linux --x64"
  },
  "dependencies": {
    "@zip.js/zip.js": "^2.7.0",
    "node-unrar-js": "^2.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "jimp": "^1.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "vite": "^5.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.akane.app",
    "productName": "Akane",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "dist-react/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Utility"
    }
  },
  "keywords": [],
  "author": "",
  "license": "MIT"
}
